function INICIO()
    global M ESTADO GANA FILA COLUMNA
    global TURNO_JUGADOR CPU CPU_DIFF
    global COLOR_P1 COLOR_P2 COLOR

    M=zeros(8,4);
    ESTADO=0;
    GANA=0;
    FILA=1;
    COLUMNA=1;
    TURNO_JUGADOR=0;
    CPU=0;
    CPU_DIFF=1;
    COLOR_P1=1;
    COLOR_P2=2;
    COLOR=1;
    
endfunction
